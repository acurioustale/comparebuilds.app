# comparebuilds — local ingest credentials (template)
# -----------------------------------------------------
# Copy to `.env` (gitignored) and fill in. These are needed ONLY by the
# build-time data ingest (scripts/ingestBlizzard.js) — never by the app at
# runtime and never deployed (only dist/ + api/ ship to the web root), so the
# repo-root `.env` is already "off the public surface". The tracked copy is this
# template only; the real `.env` must never be committed.
#
# Get a (free, instant) client at https://develop.battle.net/access/clients
# Use the "client credentials" flow — no redirect URL is actually used.

BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=

# Region for the Game Data API host + namespace (us | eu | kr | tw).
# Talent data is identical across regions; us is the default.
BLIZZARD_REGION=us

# Optional: keep credentials OUTSIDE the repo entirely (the config.php analog).
# Point this at a file containing the same KEY=VALUE lines, e.g. one level above
# the repo. When set and present, it is loaded and takes precedence over `.env`.
# BLIZZARD_CREDENTIALS_FILE=../comparebuilds-secrets.env
