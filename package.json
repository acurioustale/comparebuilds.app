{
  "name": "comparebuilds",
  "version": "1.0.0",
  "description": "World of Warcraft talent-build comparison tool (comparebuilds.app).",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerenderSpecs.js && node scripts/generateLayoutManifest.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:svg": "svgo public/favicon.svg",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:md": "markdownlint-cli2",
    "check:csp": "node tools/check-csp.mjs",
    "check:og": "node tools/check-og-image.mjs",
    "links": "lychee --config lychee.toml --root-dir public README.md CLAUDE.md SECURITY.md index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Markus Spitzner",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fast-check": "^4.8.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "dompurify": "^3.4.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "markdown-it": "^14.2.0",
    "js-yaml": "^4.3.0"
  }
}
