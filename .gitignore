# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
# Composer (PHP) — not used today, but ignore a vendor dir if one ever appears.
/vendor/

# ─── Build output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/
*.local

# ─── Tests / coverage ────────────────────────────────────────────────────────
coverage/
*.lcov
# Playwright browser smoke tests (artifacts, not the specs in e2e/)
/test-results/
/playwright-report/
/blob-report/
/.playwright/

# ─── Ingest ────────────────────────────────────────────────────────────────────
# Rejected ingest output written for inspection on a validation failure.
src/data/.invalid/

# ─── Tool caches ───────────────────────────────────────────────────────────────
.eslintcache
.stylelintcache
.lycheecache
.php-cs-fixer.cache
.phpunit.cache
.phpunit.result.cache
# Ingest caches (Blizzard API responses + DB2 tables; rebuilt on demand)
scripts/.cache/

# ─── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
# The share API's DB credentials + SHARE_IP_SALT live one level above the web
# root in production; a local copy must never be committed (the template
# api/config.php.example is tracked).
api/config.php

# Build-generated (npm run build → scripts/generateLayoutManifest.js); staged
# into the deploy by deploy.sh and reconciled server-side by ensure_schema.php.
api/current_layouts.json

# ─── OS files ────────────────────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ─── Editors / IDEs ─────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
*.sw?

# ─── Claude Code ────────────────────────────────────────────────────────────────
# Commit shared run config (launch.json); keep personal/local settings out.
.claude/settings.local.json
