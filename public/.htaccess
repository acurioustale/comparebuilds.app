# comparebuilds.app — Apache config for the static site root.
# Lives in public/ so Vite copies it into dist/ and the rsync deploy ships it
# to the web root. The SPA itself uses hash routing; the rewrite below adds
# server-rendered share pages so links unfurl with a per-build preview.

# ─── Pretty share URLs ─────────────────────────────────────────────────────────
# /s/<id> → the PHP share page (Open Graph meta + image; redirects humans to the
# SPA at /#<id>). Requires mod_rewrite; harmless if the module is absent.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^s/([A-Za-z0-9]{6})$ api/share.php?page=1&id=$1 [L,QSA]
</IfModule>


# ─── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Content-Security-Policy: everything the app needs is same-origin — bundled
  # JS/CSS/fonts, talent icons under /icons (self-hosted; see scripts/fetchIcons.js)
  # and the share API (fetch). So img-src and connect-src are 'self' only, with no
  # third-party origins. Inline styles are allowed because React sets element
  # style attributes.
  #
  # The single inline <script> the build emits is the anti-flash theme resolver in
  # index.html; it is allowlisted by its sha256 hash rather than 'unsafe-inline'.
  # IMPORTANT: that hash is over the script's exact bytes — if you edit the inline
  # script in index.html, recompute it and update the value below, or the script
  # is silently blocked (reintroducing the theme flash).
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-GBf0omRIaZT+mW0MTOPipq5S33bi82fvIP8OYMqBTMs='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"

  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "no-referrer"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # Long-cache static images. The self-hosted icons under /talent-icons are keyed
  # by a stable game slug (fetchIcons.js only ever adds files, never mutates one),
  # so they're safe to cache aggressively — this replaces the icon-cache service
  # worker that used to do this client-side. (The path is /talent-icons rather
  # than /icons because Apache reserves /icons for its autoindex graphics.)
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# ─── MIME types ────────────────────────────────────────────────────────────────
# Some hosts don't map .webmanifest by default; browsers reject the manifest
# unless it is served as application/manifest+json.
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
</IfModule>

# ─── Deny sensitive files (defense in depth) ───────────────────────────────────
# config.php normally lives ONE LEVEL ABOVE the web root and is already
# unreachable; this guards against a stray copy or template ever landing here,
# and blocks dotfiles (e.g. this .htaccess, any .env) from being served.
<FilesMatch "(^\.|\.example$|^config\.php$)">
  Require all denied
</FilesMatch>
